    "recovery:research:fast": "node scripts/research-fast-continuous.mjs --poll-sec=5 --buffer-min=6 --seed-batch=6 --duration-min=1440",
    "recovery:research:fast:once": "node scripts/research-fast-continuous.mjs --once=true --poll-sec=2 --buffer-min=6 --seed-batch=6 --duration-min=10",
    "recovery:research:fast:service:install": "node scripts/research-fast-service.mjs install",
    "recovery:research:fast:service:start": "node scripts/research-fast-service.mjs start",
    "recovery:research:fast:service:ensure": "node scripts/research-fast-service.mjs ensure",
    "recovery:research:fast:service:stop": "node scripts/research-fast-service.mjs stop",
